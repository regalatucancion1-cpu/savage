# Resend API key (https://resend.com — free tier: 100 emails/day)
# Without this, leads are logged to console but no email is sent.
RESEND_API_KEY=

# Optional: override the From address. Requires domain verified in Resend.
# Default: "Savage Web <onboarding@resend.dev>" (Resend sandbox sender)
# Example: "Savage Party <hello@savageparty.es>"
RESEND_FROM=
